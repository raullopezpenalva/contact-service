
pipeline {
    agent {
        docker {
            image 'maven:3.9.6-eclipse-temurin-21'
        }
    }
    
    stages {
        stage('Checkout') {
            steps {
                sh 'mkdir -p /app'
                sh 'cd /app'
            }
            steps {
                git branch: 'main',
                credentialsId: 'Jenkins-lab',
                url: 'https://github.com/raullopezpenalva/contact-service.git'
            }
        }
        stage('Compile') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }
        stage('Unit Tests') {
            steps {
                sh 'mvn test'
            }
        }
    }
}